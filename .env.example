# MongoDB Atlas Configuration (Cloud)
# Get your connection string from MongoDB Atlas:
# 1. Go to https://account.mongodb.com
# 2. Select your cluster
# 3. Click "Connect" button
# 4. Choose "Drivers" 
# 5. Copy the connection string and replace below
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=usersdb

# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development

# JWT Configuration
# IMPORTANT: Change this to a strong secret in production!
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production
# Microservice Integration
# Enrollment Service URL for fetching student enrollments
ENROLLMENT_SERVICE_URL=http://localhost:5003